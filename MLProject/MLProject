name: Customer Churn Model Retraining Pipeline

conda_env: conda.yaml

entry_points:
  main:
    parameters:
      n_estimators: {type: int, default: 100}
      max_depth: {type: int, default: 10}
      data_path: {type: string, default: "namadataset_preprocessing/customer_churn_preprocessing.csv"}
    command: "python modelling.py --n_estimators {n_estimators} --max_depth {max_depth} --data_path {data_path}"
